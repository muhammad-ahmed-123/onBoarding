<h1>Tasks for <%= @project.name %></h1>

<%= link_to "New task", new_project_task_path(@project) %>
<%= link_to "Back to project", @project %>

<ul>
  <% @tasks.each do |task| %>
    <li>
      <%= link_to task.title, [@project, task] %>
      (<%= task.completed? ? "done" : "pending" %>)
      <%= link_to "Edit", edit_project_task_path(@project, task) %>
      <%= button_to "Destroy", [@project, task], method: :delete, form: { data: { turbo_confirm: "Are you sure?" } } %>
    </li>
  <% end %>
</ul>
